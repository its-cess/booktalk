generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String @id @default(cuid())
  email       String @unique
  username    String @unique
  displayName String

  bio       String?
  avatarUrl String?

  isEmailVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Auth
  auth           AuthCredential?
  passwordResets PasswordResetToken[]

  // Relations
  posts        Post[]
  comments     Comment[]
  commentLikes CommentLike[]
  postLikes    PostLike[]

  followers Follow[] @relation("Following")
  following Follow[] @relation("Follower")

  notifications      Notification[] @relation("RecipientNotifications")
  actorNotifications Notification[] @relation("ActorNotifications")

  ratings  BookRating[]
  shelves  Shelf[]
  feedback Feedback[]
}

model AuthCredential {
  id     String @id @default(cuid())
  userId String @unique

  passwordHash String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id     String @id @default(cuid())
  userId String

  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Book {
  id             String @id @default(cuid())
  openLibraryKey String @unique
  title          String
  author         String
  coverUrl       String?
  description    String?

  createdAt DateTime @default(now())

  posts      Post[]
  ratings    BookRating[]
  shelfItems ShelfItem[]
}

model Post {
  id       String @id @default(cuid())
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  content          String
  bookId           String?
  book             Book?   @relation(fields: [bookId], references: [id])
  bookTitle        String?
  bookAuthor       String?
  hasSpoilers      Boolean @default(false)
  commentsDisabled Boolean @default(false)
  gifUrl           String?

  // Whether this post displays the author's rating of the linked book. The
  // value shown is the author's *current* BookRating (see BookRating), not a
  // snapshot — so changing the rating anywhere updates it everywhere.
  showsRating Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments      Comment[]
  likes         PostLike[]
  notifications Notification[]

  @@index([authorId])
  @@index([createdAt])
  @@index([bookId])
}

model Comment {
  id       String @id @default(cuid())
  postId   String
  authorId String
  content  String
  gifUrl   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post          Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes         CommentLike[]
  notifications Notification[]

  @@index([postId])
  @@index([authorId])
}

model CommentLike {
  id        String @id @default(cuid())
  commentId String
  userId    String

  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
}

model PostLike {
  id     String @id @default(cuid())
  postId String
  userId String

  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Follow {
  id String @id @default(cuid())

  followerId  String
  followingId String

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// type values: POST_LIKE | COMMENT | MENTION_POST | MENTION_COMMENT
model Notification {
  id        String  @id @default(cuid())
  userId    String
  actorId   String
  type      String
  postId    String?
  commentId String?
  read      Boolean @default(false)

  createdAt DateTime @default(now())

  user    User     @relation("RecipientNotifications", fields: [userId], references: [id], onDelete: Cascade)
  actor   User     @relation("ActorNotifications", fields: [actorId], references: [id], onDelete: Cascade)
  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, postId, type])
}

// One rating per user per book. Value is either a star rating (halfStars 0–10,
// where 10 = 5★) or DNF (dnf = true, halfStars = null). The two are mutually
// exclusive; enforced in the API/shared schema.
model BookRating {
  id     String @id @default(cuid())
  userId String
  bookId String

  halfStars Int?    // 0–10; null when dnf
  dnf       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([bookId])
}

// A user's bookshelf. Custom shelves are user-created and fully editable; the
// system "Want to Read" shelf (isSystem = true) is auto-created per user and
// cannot be renamed or deleted. Shelves are public (shown on profiles).
model Shelf {
  id        String  @id @default(cuid())
  userId    String
  name      String
  isSystem  Boolean @default(false)
  isPrivate Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ShelfItem[]

  @@unique([userId, name])
  @@index([userId])
}

model ShelfItem {
  id      String @id @default(cuid())
  shelfId String
  bookId  String

  addedAt DateTime @default(now())

  shelf Shelf @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  book  Book  @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([shelfId, bookId])
  @@index([shelfId])
  @@index([bookId])
}

// User-submitted feedback (bug report / feature request / other). Emailed to
// the site owner and stored so nothing is lost if email delivery fails.
model Feedback {
  id        String  @id @default(cuid())
  userId    String?
  type      String // "bug" | "feature" | "other"
  message   String
  url       String?
  userAgent String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}
